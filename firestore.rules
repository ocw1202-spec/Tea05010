rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // GLOBALS & HELPERS
    // -------------------------------------------------------------------------
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'ocw1202@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // MENU ITEMS
    // -------------------------------------------------------------------------
    
    match /menuItems/{itemId} {
      allow read: if true; // Publicly readable for customers
      
      allow create: if isAdmin() && isValidMenuItem(incoming());
      allow update: if isAdmin() && isValidMenuItem(incoming());
      allow delete: if isAdmin();
    }

    function isValidMenuItem(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.category is string &&
             data.prices is map &&
             (data.available == null || data.available is bool);
    }

    // -------------------------------------------------------------------------
    // ORDERS
    // -------------------------------------------------------------------------
    
    match /orders/{orderId} {
      // Admin can see all, customers only see their own
      allow list: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      
      allow create: if isSignedIn() && isValidOrder(incoming()) && incoming().customerId == request.auth.uid;
      
      allow update: if isAdmin() && (
        // Action: Update Status
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && 
         incoming().status in ['pending', 'preparing', 'ready', 'completed', 'cancelled'])
      );
    }

    function isValidOrder(data) {
      return data.customerId is string && 
             data.items is list && data.items.size() > 0 &&
             data.totalPrice is number && data.totalPrice >= 0 &&
             data.status == 'pending' &&
             data.createdAt == request.time;
    }

    // -------------------------------------------------------------------------
    // USERS
    // -------------------------------------------------------------------------
    
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isAdmin() || (isOwner(userId) && incoming().role == 'customer');
    }

    // -------------------------------------------------------------------------
    // ADMINS (Collection to manage admin list)
    // -------------------------------------------------------------------------
    
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via Firebase Console or special script
    }
  }
}
